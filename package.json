{
  "name": "film-front",
  "version": "1.3.0",
  "type": "module",
  "description": "Frontend app for matching films",
  "author": "Zhigulskii Vladislav",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "postinstall": "nuxt prepare",
    "format": "prettier --write \"**/*.ts\" \"**/*.vue\"",
    "lint": "eslint . --fix",
    "lint:check": "eslint . --max-warnings=0",
    "test": "npm run test:contract && npm run test:unit",
    "test:contract": "node scripts/check-contract.mjs",
    "test:e2e": "playwright test",
    "test:e2e:mobile-matrix": "playwright test --config=playwright.mobile.config.ts",
    "test:e2e:release": "npm run test:e2e && npm run test:e2e:mobile-matrix",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:seo": "node scripts/check-seo.mjs",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@nuxt/icon": "^2.3.1",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.3.2",
    "@vee-validate/nuxt": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.8",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.3.2",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.118",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@playwright/test": "^1.61.1",
    "@types/qrcode": "^1.5.6",
    "@vee-validate/zod": "^4.15.1",
    "prettier": "^3.9.4",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "zod": "^3.25.76"
  }
}
